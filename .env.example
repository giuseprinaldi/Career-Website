# Copy to .env.local and fill in. Never commit real secrets (.env* is gitignored).

# DeepSeek API key — powers the "Digital Twin" AI chat (/api/chat).
# Get one at https://platform.deepseek.com/  (server-side only; do NOT prefix with NEXT_PUBLIC).
DEEPSEEK_API_KEY=

# Web3Forms access key — powers the contact form. This one is public by design (it ships to
# the browser), so the NEXT_PUBLIC_ prefix is intentional. Get a free key at https://web3forms.com/
NEXT_PUBLIC_WEB3FORMS_KEY=

# Production site origin, e.g. https://joerinaldi.vercel.app — used by /api/chat to allow-list
# requests from your own domain. Optional in local dev (localhost:3000 is always allowed).
NEXT_PUBLIC_SITE_URL=
